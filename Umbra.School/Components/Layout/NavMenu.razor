@implements IDisposable

@inject NavigationManager NavigationManager

<style>
    .mud-nav-item.active {
        color: var(--mud-palette-primary);
        background-color: var(--mud-palette-action-default-hover);
    }
</style>

<MudNavMenu Rounded="true" Bordered="true" Margin="Margin.Normal" Dense>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">主页</MudNavLink>
    <AuthorizeView>
        <Authorized>
            <MudNavGroup Title="英语课程" Expanded="@IsExpanded("/english/")" Icon="@Icons.Material.Filled.Explicit" IconColor="@MudBlazor.Color.Inherit">
                <AuthorizeView Context="context_high" Roles="High School Students">
                    <Authorized>
                        <MudNavLink Href="/english/words/shsv/a" Match="NavLinkMatch.Prefix" Class="@(PageIsActive("shsv") ? "active" : "")" Icon="@Icons.Material.Filled.Abc" title="高中词汇" IconColor="@MudBlazor.Color.Inherit">高中词汇</MudNavLink>
                        <MudNavLink Href="/english/words/shsp/a" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.TextSnippet" title="高中词组" IconColor="@MudBlazor.Color.Inherit">高中词组</MudNavLink>
                        <MudNavLink Href="/english/translations" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Translate" title="语句翻译" Class="d-none" IconColor="@MudBlazor.Color.Inherit">语句翻译</MudNavLink>
                        <MudNavLink Href="/english/readings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Newspaper" title="时文阅读" Class="d-none" IconColor="@MudBlazor.Color.Inherit">时文阅读</MudNavLink>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Context="context_elementary" Roles="Elementary School Students">
                    <Authorized>
                        <MudNavLink Href="/english/words/shpsv/a" Match="NavLinkMatch.Prefix" Class="@(PageIsActive("shpsv") ? "active" : "")" Icon="@Icons.Material.Filled.Abc" title="小学词汇" IconColor="@MudBlazor.Color.Inherit">小学词汇</MudNavLink>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Context="context_elementary" Roles="Junior High School Students">
                    <Authorized>
                        <MudNavLink Href="/english/words/shjhsv/a" Match="NavLinkMatch.Prefix" Class="@(PageIsActive("shjhsv") ? "active" : "")" Icon="@Icons.Material.Filled.Abc" title="初中词汇" IconColor="@MudBlazor.Color.Inherit">初中词汇</MudNavLink>
                    </Authorized>
                </AuthorizeView>
                <MudNavLink Href="/english/words/unfamiliar/all" Match="NavLinkMatch.Prefix" Class="@(PageIsActive("unfamiliar") ? "active" : "")" Icon="@Icons.Material.Filled.Abc" title="我的生词库" IconColor="@MudBlazor.Color.Inherit">我的生词库</MudNavLink>
                <MudNavLink Href="/assessment/english/words" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Quiz" title="英语词汇专项测试" IconColor="@MudBlazor.Color.Inherit">英语词汇专项测试</MudNavLink>
                <MudNavGroup Title="水平测试" Expanded="@IsExpanded("/assessment/")" Icon="@Icons.Material.Filled.Assessment" Class="d-none" IconColor="@MudBlazor.Color.Inherit">
                    <MudNavLink Href="/assessment/english/phrases" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.TextSnippet" title="词组专项测试" Class="d-none" IconColor="@MudBlazor.Color.Inherit">词组专项测试</MudNavLink>
                    <MudNavLink Href="/assessment/english/translations" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.TextSnippet" title="翻译专项测试" Class="d-none" IconColor="@MudBlazor.Color.Inherit">翻译专项测试</MudNavLink>
                    <MudNavLink Href="/assessment/english/combined" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PresentToAll" title="综合测试" Class="d-none" IconColor="@MudBlazor.Color.Inherit">综合测试</MudNavLink>
                </MudNavGroup>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Roles="High School Students">
        <Authorized>
            <MudNavLink Href="/chinese/classicals" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Translate" title="高中语文实词" IconColor="@MudBlazor.Color.Inherit">高中语文实词</MudNavLink>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView Roles="Administrators">
        <Authorized>
            <MudNavGroup Title="测试管理" Expanded="@IsExpanded("/admin-assessment-english/")" Icon="@Icons.Material.Filled.AdminPanelSettings" IconColor="@MudBlazor.Color.Inherit">
                <MudNavLink Href="/admin-assessment-english/words" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.NewLabel" title="制定测试计划" IconColor="@MudBlazor.Color.Inherit">制定测试计划</MudNavLink>
                <MudNavLink Href="/admin-assessment-english/words/review" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Grading" title="审批测试" IconColor="@MudBlazor.Color.Inherit">审批测试</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="系统管理" Expanded="@IsExpanded("/admin/")" Icon="@Icons.Material.Filled.Settings" IconColor="@MudBlazor.Color.Inherit">
                <TitleContent>
                    <MudText Typo="Typo.subtitle2" Color="MudBlazor.Color.Inherit">系统管理</MudText>
                </TitleContent>
                <ChildContent>
                    <MudNavLink Href="/admin/users" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AdminPanelSettings" title="用户管理" IconColor="@MudBlazor.Color.Inherit">用户管理</MudNavLink>
                    <MudNavLink Href="/admin/roles" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Group" title="角色管理" IconColor="@MudBlazor.Color.Inherit">角色管理</MudNavLink>
                </ChildContent>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
    <AuthorizeView>
        <Authorized>
            <MudNavGroup Title="我的账户" Expanded="@IsExpanded("/account/")" Icon="@Icons.Material.Filled.Person2">
                <MudNavLink Href="/account/profile" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.DocumentScanner" title="我的资料" IconColor="@MudBlazor.Color.Inherit">我的资料</MudNavLink>
                <MudNavLink Href="/account/change-password" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Password" title="修改密码" IconColor="@MudBlazor.Color.Inherit">修改密码</MudNavLink>

                @* <MudNavLink Href="/account/manage" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.DocumentScanner" title="我的资料">我的资料</MudNavLink> *@
                @* <MudNavLink Href="/account/manage/changepassword" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Password" title="修改密码">修改密码</MudNavLink> *@
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
    <MudNavLink Href="/about" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Info">关于</MudNavLink>
    <MudNavLink Href="counter" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Add" Class="d-none">Counter</MudNavLink>
    <MudNavLink Href="weather" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.List" Class="d-none">Weather</MudNavLink>
    <MudNavLink Href="auth" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Lock" Class="d-none">Auth Required</MudNavLink>
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="Account/Manage" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person" Class="d-none">@context.User.Identity?.Name</MudNavLink>
            <form action="Account/Logout" method="post">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                <button type="submit" class="mud-nav-link mud-ripple d-none">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Color="MudBlazor.Color.Info" Class="mr-3"></MudIcon> Logout
                </button>
            </form>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="Account/Register" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person" Class="d-none">Register</MudNavLink>
            <MudNavLink Href="Account/Login" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Password" Class="d-none">Login</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
    <AuthorizeView Roles="Administrators">
        <Authorized>
            <MudNavLink Href="/coravel/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard" title="Job Dashboard" Target="_blank">后台管理面板 ↗</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>


@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    private bool IsExpanded(string hrefSegment)
    {
        // Checks if the current URL contains the path segment
        var expanded = NavigationManager.Uri.Contains(hrefSegment, StringComparison.OrdinalIgnoreCase);
        return expanded;
    }

    private bool PageIsActive(string book)
    {
        var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).ToLower();

        // Pattern 1: /english/words/shpsv/{alphabet}
        // Pattern 2: /english/words/shpsv/{start}/{end}
        // Both start with "english/words/shpsv"
        return uri.StartsWith($"english/words/{book}");
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

