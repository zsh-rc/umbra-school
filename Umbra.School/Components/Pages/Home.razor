@page "/"
@using Umbra.School.Models.Assessment
@using Umbra.School.Models.Dashboard
@attribute [Authorize]
@inject IDashboardService DashboardService
@inject UserProvider UserProvider;

<PageTitle>Home</PageTitle>

<MudContainer Class="mt-8 px-8 mud-full-height" MaxWidth="MaxWidth.False">
    <MudGrid>
        <MudItem xs="12">
            <MudText Typo="Typo.h4" Class="mb-4">欢迎使用Umbra 学习平台！</MudText>
        </MudItem>
        <MudItem xs="12">
            <MudField Variant="Variant.Outlined" Label="英语测试计划">
                <MudBadge Content="@_total" Color="MudBlazor.Color.Dark" Overlap="true" Bordered="true" Class="mx-6">
                    <MudButton Color="MudBlazor.Color.Dark" Variant="Variant.Filled" DropShadow="false">总计</MudButton>
                </MudBadge>
                <MudBadge Content="@_notStarted" Color="MudBlazor.Color.Error" Overlap="true" Bordered="true" Class="mx-3">
                    <MudButton Color="MudBlazor.Color.Error" Variant="Variant.Outlined" DropShadow="false"
                               Href="/assessment/english/words">
                        @AssessmentStatus.NotStarted.GetDescription()
                    </MudButton>
                </MudBadge>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="MudBlazor.Color.Primary" Class="mx-1" />
                <MudBadge Content="@_inProgress" Color="MudBlazor.Color.Warning" Overlap="true" Bordered="true" Class="mx-3">
                    <MudButton Color="MudBlazor.Color.Warning" Variant="Variant.Outlined" DropShadow="false"
                               Href="/assessment/english/words">
                        @AssessmentStatus.InProgress.GetDescription()
                    </MudButton>
                </MudBadge>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="MudBlazor.Color.Primary" Class="mx-1" />
                <MudBadge Content="@_submitted" Color="MudBlazor.Color.Secondary" Overlap="true" Bordered="true" Class="mx-3">
                    <MudButton Color="MudBlazor.Color.Secondary" Variant="Variant.Outlined" DropShadow="false"
                               Href="/assessment/english/words">
                        @AssessmentStatus.Submitted.GetDescription()
                    </MudButton>
                </MudBadge>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="MudBlazor.Color.Primary" Class="mx-1" />
                <MudBadge Content="@_reviewed" Color="MudBlazor.Color.Success" Overlap="true" Bordered="true" Class="mx-3">
                    <MudButton Color="MudBlazor.Color.Success" Variant="Variant.Outlined" DropShadow="false"
                               Href="/assessment/english/words">
                        @AssessmentStatus.Reviewed.GetDescription()
                    </MudButton>
                </MudBadge>
            </MudField>
            @* <MudGrid>
                <MudItem><MudTextField T="int" Variant="Variant.Outlined" Label="总计" @bind-Value="@_total" ReadOnly></MudTextField></MudItem>
                <MudItem><MudTextField T="int" Variant="Variant.Outlined" Label="@AssessmentStatus.NotStarted.GetDescription()" @bind-Value="@_notStarted" ReadOnly></MudTextField></MudItem>
                <MudItem><MudTextField T="int" Variant="Variant.Outlined" Label="@AssessmentStatus.InProgress.GetDescription()" @bind-Value="@_inProgress" ReadOnly></MudTextField></MudItem>
                <MudItem><MudTextField T="int" Variant="Variant.Outlined" Label="@AssessmentStatus.Submitted.GetDescription()" @bind-Value="@_submitted" ReadOnly></MudTextField></MudItem>
                <MudItem><MudTextField T="int" Variant="Variant.Outlined" Label="@AssessmentStatus.Reviewed.GetDescription()" @bind-Value="@_reviewed" ReadOnly></MudTextField></MudItem>
            </MudGrid> *@
        </MudItem>
        <MudFlexBreak />
        <MudItem xs="12" sm="6" md="8">
            <MudPaper Elevation="2" Class="pa-4">
                <ApexChart TItem="ReportUserAssessmentModel"
                           Title="测试结果统计"
                           Options="_assessmentMixedChartOptions">

                    <ApexPointSeries TItem="ReportUserAssessmentModel"
                                     Items="_myAssessmentResults"
                                     Name="词汇数量"
                                     SeriesType="SeriesType.Bar"
                                     XValue="@(e => e.AssessmentInfoName)"
                                     YValue="@(e => (decimal)e.WordsCountInvolved)"
                                     ShowDataLabels="false" />

                    <ApexPointSeries TItem="ReportUserAssessmentModel"
                                     Items="_myAssessmentResults"
                                     Name="分数"
                                     SeriesType="SeriesType.Line"
                                     XValue="@(e => e.AssessmentInfoName)"
                                     YValue="@(e => e.Score)"
                                     ShowDataLabels="true" />
                </ApexChart>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Elevation="2" Class="pa-4">
                <ApexChart TItem="ReportEnWordsCountModel"
                           Title="词汇库" Options="_englishWordsCountSeriesBarChartOptions">
                    <ApexPointSeries TItem="ReportEnWordsCountModel"
                                     Items="_englishWordsCount"
                                     Name="词汇数量"
                                     XValue="@(e => Dictionaries.WordsAssessmentScopes[e.Book])"
                                     YAggregate="@(e => e.Sum(e => e.WordsCount))"
                                     OrderByDescending="e=>e.Y"
                                     SeriesType="SeriesType.Bar"
                                     PointColor="e=> HighlightUnfamiliarColor(e)"
                                     ShowDataLabels="true" />
                </ApexChart>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    string _currentUserId = string.Empty;
    List<ReportEnWordsCountModel> _englishWordsCount = new List<ReportEnWordsCountModel>();
    List<ChartSeries<int>> _englishWordsCountSeries = new();
    ApexChartOptions<ReportEnWordsCountModel> _englishWordsCountSeriesBarChartOptions = new()
    {
        PlotOptions = new PlotOptions
        {
            Bar = new PlotOptionsBar
            {
                Horizontal = true,
            }
        },
        Yaxis = new List<YAxis> { new YAxis { Show = true } },
        Grid = new Grid
        {
            Xaxis = new GridXAxis { Lines = new Lines { Show = false } },
            Yaxis = new GridYAxis { Lines = new Lines { Show = false } }
        },
        DataLabels = new DataLabels
        {
            Enabled = true,
            Style = new DataLabelsStyle
            {
                FontSize = "20px",
                Colors = new List<string> { "#333" }
            },
            Background = new DataLabelsBackground
            {
                Enabled = true,
                ForeColor = "#fff",
                Padding = 4,
                BorderRadius = 2,
                BorderWidth = 1,
                BorderColor = "#fff",
                Opacity = 0.9
            }
        },
        Chart = new Chart { Height = 300 },
    };
    private string? HighlightUnfamiliarColor(ReportEnWordsCountModel model)
    {
        if (model.Book == "myu") { return "#FF5734"; }
        // return null;
        return "#007bc3";
    }

    List<ReportUserAssessmentModel> _myAssessmentResults = new List<ReportUserAssessmentModel>();
    ApexChartOptions<ReportUserAssessmentModel> _assessmentMixedChartOptions = new();

    int _total, _notStarted, _inProgress, _submitted, _reviewed;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _currentUserId = (await UserProvider.GetUserAsync()).UserId;
        await LoadDashboardData();
        DefineAssessmentResultChartOptions();
    }

    void DefineAssessmentResultChartOptions()
    {
        // 1. Sort data by Date (Crucial for grouping to work)
        _myAssessmentResults = _myAssessmentResults
            .OrderBy(x => x.Date)
            .ThenBy(x => x.AssessmentInfoName)
            .ToList();

        // 2. Generate the Group headers (The Date line at the bottom)
        var dateGroups = _myAssessmentResults
            .GroupBy(x => x.Date.ToString("M/d"))
            .Select(g => new XAxisGroup
            {
                Title = g.Key,
                Cols = g.Count() // Tells Apex how many bars belong under this date
            })
            .ToList();

        // 3. Configure the Chart Options
        _assessmentMixedChartOptions = new ApexChartOptions<ReportUserAssessmentModel>
        {
            Xaxis = new XAxis
            {
                Type = XAxisType.Category,
                TickPlacement = TickPlacement.Between,
                Group = new XAxisGroups
                {
                    Groups = dateGroups,
                    Style = new XAxisGroupStyle { FontSize = "12px", FontWeight = "700", Colors = new List<string> { "#555" } }
                },
                Labels = new XAxisLabels
                {
                    // Show = true,
                    Formatter = "function(val) { return ''; }",
                    // Rotate = -45, // Rotates AssessmentNames if they are long
                    // Style = new AxisLabelStyle { FontSize = "10px" }
                    MinHeight = 20
                },
            },
            Yaxis = new List<YAxis>
            {
                new YAxis // First Y-Axis (Left)
                {
                    Title = new AxisTitle { Text = "词汇数量" },
                    Min = 0,
                    ForceNiceScale = true
                },
                new YAxis // Second Y-Axis (Right)
                {
                    Opposite = true,
                    Title = new AxisTitle { Text = "分数" },
                    Min = 0,
                    Max = 110,
                    TickAmount = 10
                }
            },
            DataLabels = new DataLabels
            {
                Enabled = true, // Shows labels for both Bar and Line
                Formatter = "function(val) { return val; }",
                EnabledOnSeries = new List<double> { 0, 1 },
                OffsetY = -5,  // Slightly offsets labels above the points/bars
                Style = new DataLabelsStyle
                {
                    FontSize = "12px",
                    Colors = new List<string> { "#333" }
                },
                Background = new DataLabelsBackground
                {
                    Enabled = true,
                    ForeColor = "#fff",
                    Padding = 4,
                    BorderRadius = 2,
                    BorderWidth = 1,
                    BorderColor = "#fff",
                    Opacity = 0.9
                }
            },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar
                {
                    DataLabels = new PlotOptionsBarDataLabels
                    {
                        Position = BarDataLabelPosition.Center
                    }
                }
            },
            Grid = new Grid()
            {
                Padding = new Padding { Bottom = 0 }
            },
            Chart = new Chart { Height = 300 },
        };
    }

    async Task LoadDashboardData()
    {
        _englishWordsCount = await DashboardService.GetReportEnWordsCounts(_currentUserId);
        _myAssessmentResults = await DashboardService.GetReportUserAssessments(_currentUserId);
        var status = await DashboardService.GetReportUserAssessmentStatuses(_currentUserId);
        if (status != null)
        {
            _total = status.Total;
            _notStarted = status.NotStarted;
            _inProgress = status.InProgress;
            _submitted = status.Submitted;
            _reviewed = status.Reviewed;
        }
    }

}