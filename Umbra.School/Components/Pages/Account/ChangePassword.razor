@page "/account/change-password"
@using Umbra.School.Models.Account
@inject UserProvider UserProvider
@inject IAccountService AccountService
@inject AppSnackbarService AppSnackbarService

<MudPaper Elevation="0" Class="transparent-bg mb-3" Square="true">
    <MudToolBar Dense="true">
        <MudText Typo="Typo.h6" Style="font-weight:bold;">修改密码<MudText Typo="Typo.caption" GutterBottom="true" Color="MudBlazor.Color.Secondary">（至少六位并至少包含一位大小写字母和数字）</MudText></MudText>
        <MudSpacer />
    </MudToolBar>
    <MudDivider DividerType="DividerType.FullWidth" />
</MudPaper>

<MudPaper Class="pa-3" Elevation="0">
    <MudGrid>
        <MudItem xs="6">
            <MudForm Model="_model">
                <MudTextField For="@(() => _model.OldPassword)" @bind-Value="@_model.OldPassword" InputType="InputType.Password" Required="true"
                              Label="密码" Placeholder="当前密码" HelperText="请输入当前密码。"
                              UserAttributes="@(new() { { "autocomplete", "current-password" }, { "aria-required", "true" } })" />
                <MudTextField For="@(() => _model.NewPassword)" @bind-Value="@_model.NewPassword" InputType="InputType.Password"
                              Label="新密码" Placeholder="新密码" HelperText="请输入新密码" Required="true"
                              UserAttributes="@(new() { { "autocomplete", "new-password" }, { "aria-required", "true" } })" />
                <MudTextField For="@(() => _model.ConfirmPassword)" @bind-Value="_model.ConfirmPassword" InputType="InputType.Password"
                              Label="确认新密码" Placeholder="确认新密码" HelperText="请输入确认新密码" Required="true"
                              UserAttributes="@(new() { { "autocomplete", "new-password" }, { "aria-required", "true" } })" />
                <MudButton StartIcon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="MudBlazor.Color.Primary" FullWidth="true" Class="mt-5"
                OnClick="ChangeUserPassword">保存密码</MudButton>
            </MudForm>
        </MudItem>
        <MudItem xs="6"></MudItem>
    </MudGrid>
</MudPaper>

@code {
    ChangePasswordModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        var user = await UserProvider.GetUserAsync();        
        _model.UserId = user.UserId;
    }

    async Task ChangeUserPassword()
    {
        var result = await AccountService.ChangePassword(_model);
        if (result.Success)
        {
            AppSnackbarService.ShowSuccess($"密码修改成功。");
        }
        else
        {
            AppSnackbarService.ShowError($"修改失败，确保当前密码正确和新密码符合规范。");
        }
    }

}
